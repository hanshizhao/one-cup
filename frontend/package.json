{
  "name": "one-cup-frontend",
  "version": "1.0.0",
  "description": "OneCup 印染厂面料开发管理系统前端",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "eslint": "eslint src/ --ext .ts,.tsx,.js,.jsx --fix --cache",
    "stylelint": "stylelint 'src/**/*.less' 'src/**/*.css' --fix --cache",
    "pre-commit": "pretty-quick --staged && npm run eslint && npm run stylelint",
    "prepare": "husky install && husky add .husky/pre-commit 'npm run pre-commit'"
  },
  "dependencies": {
    "@arco-design/color": "^0.4.0",
    "@arco-design/web-react": "^2.32.2",
    "@arco-plugins/vite-react": "^1.0.5",
    "@arco-themes/react-arco-pro": "^0.0.7",
    "@reduxjs/toolkit": "^2.2.0",
    "axios": "^1.7.0",
    "classnames": "^2.3.1",
    "esbuild": "^0.28.1",
    "lodash": "^4.17.21",
    "nprogress": "^0.2.0",
    "query-string": "^6.13.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-redux": "^9.1.0",
    "react-router": "^6.26.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@arco-plugins/vite-plugin-svgr": "^0.7.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.10.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.3.0",
    "husky": "^7.0.2",
    "jsdom": "^29.1.1",
    "less": "^4.1.2",
    "postcss-less": "4",
    "prettier": "^2.4.1",
    "pretty-quick": "^3.1.2",
    "stylelint": "^14.1.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-standard": "^24.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --cache"
    ],
    "*.{css, less}": [
      "stylelint --fix"
    ]
  }
}
