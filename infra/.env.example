# ─────────────────────────────────────────────────────────────
# OneCup 部署配置
# 使用前: 复制本文件为 .env 并填入真实值
#   cp .env.example .env
#
# 注意: .env 文件包含密码/密钥, 不要提交到 git (已在 .gitignore 中忽略)
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────

# 数据库名称
POSTGRES_DB=onecup

# 数据库用户名
POSTGRES_USER=onecup

# 数据库密码 — 请使用强密码! (至少 16 位, 含大小写字母+数字+符号)
POSTGRES_PASSWORD=请替换为强密码

# 宿主机映射端口 (容器内始终 5432; 仅在 docker-compose.yml 取消 postgres.ports 注释时生效)
POSTGRES_PORT=15207

# ── pgAdmin ───────────────────────────────────────────────────

# pgAdmin 登录邮箱
PGADMIN_EMAIL=admin@onecup.local

# pgAdmin 登录密码 — 请使用强密码!
PGADMIN_PASSWORD=请替换为强密码

# pgAdmin 宿主机映射端口 (容器内始终 80)
PGADMIN_PORT=15672

# ── 后端 (.NET API) ──────────────────────────────────────────

# JWT 签发密钥 — 生产必须替换! 至少 32 字节随机字符串
# 可用命令生成: openssl rand -base64 48
JWT_SECRET=请替换为至少32字节的随机字符串

# 后端宿主机映射端口 (容器内始终 5000)
BACKEND_PORT=5000

# ── 前端 (nginx) ─────────────────────────────────────────────

# 前端宿主机映射端口 (容器内始终 80)
FRONTEND_PORT=8080

# 服务器对外主机名/IP (用于 CORS 兜底配置; 生产填服务器公网 IP 或域名)
SERVER_HOST=localhost
