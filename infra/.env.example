# ─────────────────────────────────────────────────────────────
# 开发环境数据库配置
# 使用前: 复制本文件为 .env 并填入真实值
#   cp .env.example .env
#
# 注意: .env 文件包含密码, 不要提交到 git (已在 .gitignore 中忽略)
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────

# 数据库名称
POSTGRES_DB=onecup

# 数据库用户名
POSTGRES_USER=onecup

# 数据库密码 — 请使用强密码! (至少 16 位, 含大小写字母+数字+符号)
POSTGRES_PASSWORD=请替换为强密码

# 宿主机映射端口 (容器内始终 5432)
POSTGRES_PORT=15207

# ── pgAdmin ───────────────────────────────────────────────────

# pgAdmin 登录邮箱
PGADMIN_EMAIL=admin@onecup.local

# pgAdmin 登录密码 — 请使用强密码!
PGADMIN_PASSWORD=请替换为强密码

# pgAdmin 宿主机映射端口 (容器内始终 80)
PGADMIN_PORT=15672
